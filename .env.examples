# ── Cloudinary ──────────────────────────────
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# ── Mapbox ───────────────────────────────────
MAP_TOKEN=your_mapbox_access_token

# ── Session ──────────────────────────────────
SECRET=your_session_secret_any_string

# ── MongoDB ──────────────────────────────────
# For local Docker: mongodb://mongo:27017/wanderlust
# For Atlas:        mongodb+srv://<user>:<pass>@cluster.mongodb.net/wanderlust
ATLASDB_URL=mongodb://mongo:27017/wanderlust

# ── Ollama ───────────────────────────────────
# For Docker Compose: http://ollama:11434
# For local dev:      http://localhost:11434
OLLAMA_URL=http://ollama:11434

